# Optional environment overrides for openvpnd (systemd EnvironmentFile).
# Install as /etc/openvpnd/openvpnd.env (mode 0600) and set real values.
# Keys also work as process env (prefix OPENVPND_).

# API bearer token (required in production — never leave the config default).
# OPENVPND_AUTH_TOKEN=replace-with-a-long-random-secret

# Refuse insecure defaults (default token, mock backend, open SNMP community).
# Leave at 0 on real hosts. Set to 1 only for local lab/dev.
OPENVPND_ALLOW_INSECURE=0

# Optional path / listen overrides (YAML still wins unless these are set).
# OPENVPND_DB_PATH=/var/lib/openvpnd/state.db
# OPENVPND_LISTEN_HTTP=127.0.0.1:51980
# OPENVPND_PUBLIC_BASE_URL=https://vpn.example.com
